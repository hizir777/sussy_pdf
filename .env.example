# ===== Sussy PDF - Çevresel Değişkenler =====
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# cp .env.example .env

# --- VirusTotal API ---
# Ücretsiz kayıt: https://www.virustotal.com/gui/join-us
# Ücretsiz API: 4 istek/dakika, 500 istek/gün
VIRUSTOTAL_API_KEY=your_api_key_here

# --- Analiz Ayarları ---
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
ANALYSIS_TIMEOUT_SECONDS=300

# --- YARA Kuralları ---
YARA_RULES_PATH=specs/yara_rules/

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8443

# --- Docker Sandbox ---
SANDBOX_ENABLED=false
SANDBOX_TIMEOUT=120
SANDBOX_NETWORK=none

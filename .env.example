# 🔑 Ortam Değişkenleri (.env.example)
#
# SETUP INSTRUCTIONS:
# 1. cp .env.example .env
# 2. Edit .env and fill in your values
# 3. Never commit .env to Git!

# ============================================
# 📊 API & 3. TARAF HİZMETLER
# ============================================

# VirusTotal Integration (Optional)
# Ücretsiz kayıt: https://www.virustotal.com/gui/join-us
# Ücretsiz API: 4 istek/dakika, 500 istek/gün
VIRUSTOTAL_API_KEY=your_vt_api_key_here
VIRUSTOTAL_RATE_LIMIT=4

# URLhaus / Abuse.ch Integration (Optional)
URLHAUS_API_KEY=
ABUSEIP_API_KEY=

# Custom Threat Intel Feeds (Optional)
MISP_URL=https://misp.instance.com
MISP_API_KEY=

# ============================================
# 🔐 KIMLIK DOĞRULAMA & GÜVENLİK
# ============================================

# API Key (For JWT authentication - v1.1.0+)
API_KEY_SECRET=your_super_secret_key_change_this_in_production
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Settings
CORS_ORIGINS=["http://localhost:8443", "http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting (v1.1.0+)
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=600
RATE_LIMIT_ENABLED=true

# ============================================
# 📁 PATH & DOSYA AYARLARI
# ============================================

# Working Directories
WORK_DIR=./output
TEMP_DIR=./temp
PDF_UPLOAD_DIR=./uploads
SAMPLE_REPORTS_DIR=./output
LOG_DIR=./logs

# Max File Sizes
MAX_FILE_SIZE_MB=500
MAX_BATCH_SIZE=100

# ============================================
# 🔍 ANALİZ AYARLARI
# ============================================

# Timeout Settings (seconds)
ANALYSIS_TIMEOUT=300
UPLOAD_TIMEOUT=60
STREAM_DECODE_TIMEOUT=30

# JavaScript Emulation
JS_EMULATION_ENABLED=true
JS_SANDBOX_ENABLED=true
ANTI_EVASION_CHECK=true

# YARA Scanning
YARA_RULES_PATH=./specs/yara_rules
YARA_SCAN_ENABLED=true

# ============================================
# 📊 RAPORLAMA
# ============================================

# Output Formats (comma-separated: json,html,md,ioc)
OUTPUT_FORMATS=json,html
REPORT_LANGUAGE=en

# Email Integration (Optional - v1.3.0+)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
REPORT_EMAIL_RECIPIENTS=admin@example.com

# ============================================
# 🗄️ VERİTABANı (v1.1.0+ için)
# ============================================

# SQLite (local development)
SQLITE_DB_PATH=./data/sussy_pdf.db

# PostgreSQL (Optional - for future enterprise support)
DATABASE_URL=postgresql://user:password@localhost:5432/sussy_pdf

# ============================================
# 📝 LOGGING
# ============================================

# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FORMAT=json

# Log Files
LOG_FILE=./logs/sussy_pdf.log
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=5

# ============================================
# 🔧 UYGULAMA AYARLARI
# ============================================

# FastAPI Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8443
DEBUG=false
RELOAD=false

# Python Environment
PYTHONIOENCODING=utf-8
PYTHONUNBUFFERED=1

# Workers (for async processing)
WORKER_COUNT=4
WORKER_TIMEOUT=300

# ============================================
# 🐳 DOCKER AYARLARI
# ============================================

CONTAINER_NAME=sussy-pdf-api
IMAGE_TAG=1.0.0
DOCKER_REGISTRY=docker.io

# ============================================
# 🔒 GÜVENLİK (PRODUCTION)
# ============================================

# HTTPS/SSL (v1.1.0+)
SSL_ENABLED=false
SSL_CERT_PATH=/etc/ssl/certs/sussy-pdf.crt
SSL_KEY_PATH=/etc/ssl/private/sussy-pdf.key

# Security Headers
CONTENT_SECURITY_POLICY=default-src 'self'
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# ============================================
# 📈 MONİTÖRİNG & OBSERVABİLİTY
# ============================================

# Prometheus Metrics (Optional)
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Sentry Error Tracking (Optional)
SENTRY_DSN=

# ============================================
# 🤖 MAKINE ÖĞRENMESI (v1.4.0+)
# ============================================

# Model Configuration
ML_MODEL_PATH=./models/pdf_classifier_v1.onnx
ML_MODEL_VERSION=1.0.0
ML_CONFIDENCE_THRESHOLD=0.85

# Training Data
ML_TRAINING_ENABLED=false
ML_DATASET_PATH=./data/training_samples

# --- Docker Sandbox ---
SANDBOX_ENABLED=false
SANDBOX_TIMEOUT=120
SANDBOX_NETWORK=none
